CATALOG_ROOT=C:\Users\kash-\Python_kash
HOST=127.0.0.1
PORT=8002
MAX_UPLOAD_MB=25
MAX_FILE_READ_MB=50
SCAN_EXCLUDE_DIRS=.venv,node_modules,__pycache__,.git,05data/rag_index,site-packages,dist,build,.mypy_cache
SCAN_EXCLUDE_GLOB=*.pyc,*.exe
DEEPSEEK_API_KEY=
