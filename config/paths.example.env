# Скопировать в корень модуля backend как .env (не коммитить)

# Каноническая папка чистовых статей для индекса (создать на G: при миграции)
RAG_SOURCE_PATH=G:\3_Дзен\1G_канал про ИИ_статьи на Дзене\4_AIKIVAVIORA_база-RAG

# Локальный индекс (генерируется ingest; путь от корня филиала)
RAG_INDEX_PATH=05data/rag_index

# DeepSeek (облако)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LM Studio (локально, OpenAI-compatible)
# 1) LM Studio → Local Server → Start Server (порт 1234)
# 2) Имя модели — на вкладке сервера (часто подходит local-model)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model

# Кто отвечает в чате при provider=auto: auto | deepseek | lm_studio
RAG_LLM_DEFAULT=lm_studio

# Embeddings (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Chunking (ingest)
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# Безопасность API (локально)
RAG_MAX_UPLOAD_MB=25
RAG_CORS_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
